<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/new_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/detail_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/detail_back"
            android:padding="12dp"
            android:src="@drawable/ic_nav_back"
            android:tint="@color/new_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/oil_change_detail_title"
            android:textColor="@color/new_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/new_card_background"
                android:elevation="5dp"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingEnd="16dp"
                android:paddingBottom="20dp">

                <!-- Data da troca -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_detail_date_label"
                    android:textColor="@color/new_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detail_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/new_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Km atual -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/oil_change_detail_km_label"
                    android:textColor="@color/new_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detail_km"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/new_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Km para próxima troca -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/oil_change_detail_next_label"
                    android:textColor="@color/new_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/detail_next"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/new_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Observações (opcional) -->
                <TextView
                    android:id="@+id/detail_notes_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/oil_change_detail_notes_label"
                    android:textColor="@color/new_text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/detail_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/new_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Tipo de óleo (opcional) -->
                <TextView
                    android:id="@+id/detail_oil_type_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/oil_change_detail_oil_type_label"
                    android:textColor="@color/new_text_secondary"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/detail_oil_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/new_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="18dp"
                    android:background="@color/new_divider" />

                <!-- Itens trocados -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/oil_change_detail_items_label"
                    android:textColor="@color/new_text_secondary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/detail_items_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/detail_no_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/oil_change_no_items_selected"
                    android:textColor="@color/new_text_muted"
                    android:textSize="14sp"
                    android:visibility="gone" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Botões -->
    <Button
        android:id="@+id/detail_edit_btn"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/new_secondary_button"
        android:text="@string/oil_change_edit_btn"
        android:textColor="@color/new_blue"
        android:textSize="15sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/detail_delete_btn"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/new_secondary_button_red"
        android:text="@string/oil_change_delete_btn_label"
        android:textColor="@color/new_red"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>
