<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/new_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="10dp">

        <ImageView
            android:id="@+id/edit_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/detail_back"
            android:padding="12dp"
            android:src="@drawable/ic_nav_back"
            android:tint="@color/new_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/oil_change_edit_title"
            android:textColor="@color/new_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/new_card_background"
                android:elevation="5dp"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="20dp"
                android:paddingEnd="16dp"
                android:paddingBottom="20dp">

                <!-- Data da troca -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_date_label"
                    android:textColor="@color/new_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/new_input_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="12dp">

                    <EditText
                        android:id="@+id/edit_date"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:textColor="@color/new_text_primary"
                        android:textColorHint="@color/new_text_muted"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feature_clock"
                        android:tint="@color/new_text_muted" />
                </LinearLayout>

                <!-- Km atual -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/oil_change_km_current_label"
                    android:textColor="@color/new_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/new_input_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/edit_km"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="@string/oil_change_km_hint"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:maxLength="9"
                        android:textColor="@color/new_text_primary"
                        android:textColorHint="@color/new_text_muted"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/oil_change_km_unit"
                        android:textColor="@color/new_text_muted"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Km para próxima troca -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/oil_change_next_km_label"
                    android:textColor="@color/new_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/new_input_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <EditText
                        android:id="@+id/edit_next_km"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:importantForAutofill="no"
                        android:inputType="number"
                        android:maxLength="9"
                        android:textColor="@color/new_text_primary"
                        android:textColorHint="@color/new_text_muted"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/oil_change_km_unit"
                        android:textColor="@color/new_text_muted"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Data prevista -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/oil_change_next_date_required_label"
                    android:textColor="@color/new_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/new_input_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="12dp">

                    <EditText
                        android:id="@+id/edit_next_date"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:inputType="none"
                        android:textColor="@color/new_text_primary"
                        android:textColorHint="@color/new_text_muted"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_feature_clock"
                        android:tint="@color/new_text_muted" />
                </LinearLayout>

                <!-- Tipo de óleo (só se preenchido) -->
                <TextView
                    android:id="@+id/edit_oil_type_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/oil_change_detail_oil_type_label"
                    android:textColor="@color/new_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/edit_oil_type"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/new_input_bg"
                    android:hint="@string/oil_change_oil_type_hint"
                    android:importantForAutofill="no"
                    android:inputType="textCapSentences"
                    android:maxLength="50"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="@color/new_text_primary"
                    android:textColorHint="@color/new_text_muted"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <!-- Observações (só se preenchido) -->
                <TextView
                    android:id="@+id/edit_notes_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/oil_change_detail_notes_label"
                    android:textColor="@color/new_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/edit_notes"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/new_input_bg"
                    android:gravity="top|start"
                    android:hint="@string/oil_change_notes_hint"
                    android:importantForAutofill="no"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLength="120"
                    android:overScrollMode="never"
                    android:paddingStart="14dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="14dp"
                    android:paddingBottom="8dp"
                    android:scrollbars="none"
                    android:textColor="@color/new_text_primary"
                    android:textColorHint="@color/new_text_muted"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <!-- Itens trocados -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/oil_change_detail_items_label"
                    android:textColor="@color/new_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <CheckBox
                    android:id="@+id/edit_cb_engine_oil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/oil_change_engine_oil"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/edit_cb_oil_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_oil_filter"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/edit_cb_air_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_air_filter"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/edit_cb_fuel_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_fuel_filter"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/edit_cb_cabin_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_cabin_filter"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/edit_cb_brake_fluid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_brake_fluid"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

                <CheckBox
                    android:id="@+id/edit_cb_spark_plugs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_spark_plugs"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Botão Salvar alterações -->
    <Button
        android:id="@+id/edit_save_btn"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/new_primary_button"
        android:text="@string/oil_change_save_changes_btn"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>
