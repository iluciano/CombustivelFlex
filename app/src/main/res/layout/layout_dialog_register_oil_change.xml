<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="8dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp">

        <!-- Data da troca -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/oil_change_date_label"
            android:textColor="@color/new_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/dialog_oil_date"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="@string/oil_change_date_hint"
            android:inputType="text"
            android:maxLength="10"
            android:textColor="@color/new_text_primary"
            android:textColorHint="@color/new_text_muted"
            android:textSize="16sp" />

        <!-- Quilometragem -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/oil_change_km_label"
            android:textColor="@color/new_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/dialog_oil_km"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="@string/oil_change_km_hint"
            android:inputType="number"
            android:textColor="@color/new_text_primary"
            android:textColorHint="@color/new_text_muted"
            android:textSize="16sp" />

        <!-- Itens trocados -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/oil_change_items_changed_label"
            android:textColor="@color/new_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/dialog_check_engine_oil"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:checked="true"
            android:text="@string/oil_change_engine_oil"
            android:textColor="@color/new_text_primary"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/dialog_check_oil_filter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="@string/oil_change_oil_filter"
            android:textColor="@color/new_text_primary"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/dialog_check_air_filter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/oil_change_air_filter"
            android:textColor="@color/new_text_primary"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/dialog_check_cabin_filter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/oil_change_cabin_filter"
            android:textColor="@color/new_text_primary"
            android:textSize="14sp" />

        <!-- Intervalo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/oil_change_interval_label"
            android:textColor="@color/new_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/dialog_interval_km"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:inputType="number"
                    android:text="5000"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="km"
                    android:textColor="@color/new_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/dialog_interval_months"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:inputType="number"
                    android:text="6"
                    android:textColor="@color/new_text_primary"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/oil_change_months"
                    android:textColor="@color/new_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
